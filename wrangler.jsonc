{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bb-realty-auctions",
  "compatibility_date": "2026-06-14",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bb-realty-auctions-production",
      "database_id": ""
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "bb-realty-auctions-images"
    }
  ]
}